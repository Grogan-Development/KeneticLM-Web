# MiniMax Token Plan API
# Get API key from https://platform.minimax.io/user-center/basic-information/interface-key
# Note: Token Plan API Key is different from pay-as-you-go API Keys
MINIMAX_API_KEY=your_minimax_token_plan_key_here
MINIMAX_BASE_URL=https://api.minimax.io/anthropic

# Daytona Configuration
# Get API key from https://app.daytona.io/dashboard/settings/api-keys
DAYTONA_API_KEY=your_daytona_api_key_here
DAYTONA_SERVER_URL=https://app.daytona.io/api
DAYTONA_TARGET=us

# Optional: Next.js public URL
NEXT_PUBLIC_APP_URL=http://localhost:3000
